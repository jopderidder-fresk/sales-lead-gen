{$DOMAIN} {
	# Backend API and health check
	handle /api/* {
		reverse_proxy backend:8000 {
			transport http {
				keepalive 30s
				keepalive_idle_conns 8
			}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /health {
		reverse_proxy backend:8000
	}

	# Frontend (everything else)
	handle {
		reverse_proxy frontend:80
	}
}
