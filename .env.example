# =============================================================================
# Sales Platform — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- Application ---
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
APP_DEBUG=true               # Enable debug mode (disable in production)
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:5173"]  # JSON array of allowed origins

# --- PostgreSQL ---
POSTGRES_USER=sales
POSTGRES_PASSWORD=sales
POSTGRES_DB=sales
POSTGRES_HOST=postgres       # Docker service name
POSTGRES_PORT=5432
# DATABASE_URL is auto-built from POSTGRES_* vars when left unset
SQL_ECHO=false

# --- Redis ---
REDIS_HOST=redis             # Docker service name
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis
# REDIS_URL, CELERY_BROKER_URL, and CELERY_RESULT_BACKEND are auto-built
# from REDIS_HOST, REDIS_PORT, and REDIS_PASSWORD when left unset.

# --- JWT Authentication ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth SSO ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_ALLOWED_DOMAINS=company.com,partner.com  # Restrict login to specific email domains

# --- Encryption ---
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Required in production for encrypting API keys at rest in the database.
FERNET_KEY=

# --- External API Keys ---
# FIRECRAWL_API_KEY=
# HUNTER_IO_API_KEY=
# BEDRIJFSDATA_API_KEY=
# APOLLO_API_KEY=
# SCRAPIN_API_KEY=
# ANTHROPIC_API_KEY=
# APIFY_API_TOKEN=

# --- LLM Provider ---
# LLM_PROVIDER=anthropic           # anthropic | openrouter | gemini | google_vertex
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=minimax/minimax-m2.5:free
# GEMINI_API_KEY=
# GEMINI_FAST_MODEL=gemini-2.5-flash
# GEMINI_STRONG_MODEL=gemini-2.5-pro

# --- Google Vertex AI (service account auth) ---
# Option A: path to a JSON key file (local dev or mounted secret volume)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account.json
# Option B: raw JSON content (for CI, Docker secrets, cloud secret managers)
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# GOOGLE_VERTEX_PROJECT_ID=         # GCP project ID (auto-detected from key if unset)
# GOOGLE_VERTEX_LOCATION=europe-west1
# GOOGLE_VERTEX_FAST_MODEL=gemini-3.1-flash-lite-preview
# GOOGLE_VERTEX_STRONG_MODEL=gemini-3.1-flash-lite-preview

# --- CRM Integration ---
# CRM_PROVIDER=                 # "clickup" or "" (none) — selects the active CRM provider
#                               # Can also be configured at runtime via Settings UI.

# --- ClickUp (CRM provider) ---
# Get IDs from your ClickUp URL: https://app.clickup.com/{WORKSPACE_ID}/v/o/f/{FOLDER_ID}
# Use the API to discover Space and List IDs: https://developer.clickup.com/reference/getspaces
# CLICKUP_API_KEY=              # Personal API token (pk_...) or OAuth token
# CLICKUP_WORKSPACE_ID=         # ClickUp workspace/team ID (numeric, from URL)
# CLICKUP_SPACE_ID=             # Space ID (get via API: GET /team/{workspace_id}/space)
# CLICKUP_FOLDER_ID=            # Folder ID within the space (from URL)
# CLICKUP_LIST_ID=              # Default list ID for new lead tasks (get via API: GET /folder/{folder_id}/list)
# CLICKUP_DOMAIN_FIELD_ID=      # Custom field ID for domain-based task deduplication

# --- ClickUp Person Task Settings (for pushing contacts as separate Person tasks) ---
# CLICKUP_PERSON_LIST_ID=              # List ID for Person/Contact tasks
# CLICKUP_PERSON_EMAIL_FIELD_ID=       # Custom field ID for email
# CLICKUP_PERSON_PHONE_FIELD_ID=       # Custom field ID for phone number
# CLICKUP_PERSON_LINKEDIN_FIELD_ID=    # Custom field ID for LinkedIn URL
# CLICKUP_PERSON_SURNAME_FIELD_ID=     # Custom field ID for first name
# CLICKUP_PERSON_LASTNAME_FIELD_ID=    # Custom field ID for last name
# CLICKUP_PERSON_ROLE_FIELD_ID=        # Custom field ID for role/title
# CLICKUP_CONTACT_RELATIONSHIP_FIELD_ID= # Person → Company relationship field ID
# CLICKUP_COMPANY_CONTACT_FIELD_ID=    # Company → Person relationship field ID

# --- Frontend URL (for links in Slack notifications) ---
# FRONTEND_URL=http://localhost:5173

# --- Slack Notifications ---
# SLACK_WEBHOOK_URL=            # Incoming webhook URL for immediate alerts
# SLACK_DIGEST_WEBHOOK_URL=     # Separate webhook URL for digests (falls back to primary)
# SLACK_DIGEST_HOUR=9           # Hour (UTC) for daily digest delivery (0-23)
# SLACK_WEEKLY_DAY=0            # Day of week for weekly summary (0=Monday, 6=Sunday)

# --- Usage Limits (Cost Management) ---
# MAX_COMPANIES_PER_DISCOVERY_RUN=50          # Cap on companies added per single discovery run
# MAX_DISCOVERY_RUNS_PER_DAY=5                # Max manual + scheduled discovery runs per day
# MAX_ENRICHMENTS_PER_DAY=100                 # Max enrichment jobs dispatched per day
# MAX_SCRAPES_PER_DAY=50                      # Max Firecrawl scrape jobs per day
# MAX_MONITORING_COMPANIES_PER_RUN=200        # Max companies monitored per batch run
# DAILY_API_COST_LIMIT=25                     # Daily cost cap in EUR (0 = unlimited)
